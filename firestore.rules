rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - allow authenticated users to read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to read all users for chat functionality
    match /users/{userId} {
      allow read: if request.auth != null;
    }

    // Chat messages - allow authenticated users to read/write messages
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Chat metadata - allow authenticated users to read/write chat info
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }

    // Push notification tokens - allow users to manage their own tokens
    match /users/{userId}/tokens/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}